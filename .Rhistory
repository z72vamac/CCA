out <- CCA(x=rna,z=dna[,chrom==1], typex="standard", typez="ordered", penaltyx=perm.out$bestpenaltyx, v=perm.out$v.init, penaltyz=perm.out$bestpenaltyz, xnames=substr(genedesc,1,20), znames=paste("Pos", sep="", nuc[chrom==1]))
